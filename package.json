{
  "name": "gittui",
  "version": "0.1.0",
  "description": "Modern terminal git client",
  "type": "module",
  "bin": {
    "gittui": "./src/index.ts"
  },
  "files": [
    "src/",
    "dist/"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rsbmk/gittui.git"
  },
  "homepage": "https://github.com/rsbmk/gittui",
  "bugs": {
    "url": "https://github.com/rsbmk/gittui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun --preload @opentui/solid/preload --hot src/index.ts",
    "build": "bun --preload @opentui/solid/preload build --compile --outfile=gittui src/index.ts",
    "build:all": "bun run scripts/build.ts",
    "build:current": "bun run scripts/build.ts --current",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "dependencies": {
    "@opentui-ui/dialog": "^0.1.2",
    "@opentui/core": "^0.1.84",
    "@opentui/solid": "^0.1.84",
    "smol-toml": "^1.6.0",
    "solid-js": "^1.9.11"
  }
}
